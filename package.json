{
  "name": "devmate",
  "version": "1.0.0",
  "description": "DevMate - Developer Community Platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "build:prod": "npm install && npm run build && npm run copy:build",
    "copy:build": "if exist \"server\\client\\build\" rmdir /s /q \"server\\client\\build\" && xcopy \"client\\build\" \"server\\client\\build\" /e /i /q",
    "start": "node server/server.js",
    "start:prod": "node server/server.js",
    "test": "cd server && npm test"
  },
  "keywords": [
    "mern",
    "react",
    "nodejs",
    "mongodb",
    "developer-community"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.1"
  }
}
